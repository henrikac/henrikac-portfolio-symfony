{% extends 'admin/base.html.twig' %}

{% block title %}Log in | Admin{% endblock %}

{% block body %}
    <section class="mx-auto max-w-md">
        <div class="mb-8 text-center">
            <p class="text-sm font-semibold uppercase tracking-wide text-[#b94635]">Admin</p>
            <h1 class="mt-3 text-3xl font-semibold tracking-tight text-[#13251f]">Log in</h1>
            <p class="mt-3 text-sm leading-6 text-[#52615b]">Manage which GitHub repositories are shown on the public site.</p>
        </div>

        <form method="post" class="rounded-xl border border-[#c8d7d0] bg-[#fbfcfa] p-6 shadow-sm">
            {% if error %}
                <div class="mb-5 rounded-lg border border-[#e3b4aa] bg-[#f3ded8] px-4 py-3 text-sm font-medium text-[#8d2f22]">
                    {{ error.messageKey|trans(error.messageData, 'security') }}
                </div>
            {% endif %}

            <div>
                <label for="email" class="block text-sm font-semibold text-[#263a33]">Email</label>
                <input type="email" name="email" id="email" class="mt-2 block w-full rounded-lg border border-[#bacbc4] bg-white px-3 py-2.5 text-[#13251f] outline-none transition placeholder:text-[#8aa39a] focus:border-[#176d72] focus:ring-4 focus:ring-[#d7ecef]" required autofocus>
            </div>

            <div class="mt-5">
                <label for="password" class="block text-sm font-semibold text-[#263a33]">Password</label>
                <input type="password" name="password" id="password" class="mt-2 block w-full rounded-lg border border-[#bacbc4] bg-white px-3 py-2.5 text-[#13251f] outline-none transition placeholder:text-[#8aa39a] focus:border-[#176d72] focus:ring-4 focus:ring-[#d7ecef]" required>
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <div class="mt-6 flex justify-end">
                <button class="inline-flex items-center gap-2 rounded-lg bg-[#13251f] px-4 py-2.5 text-sm font-semibold text-[#fbfcfa] transition hover:bg-[#213a32]" type="submit">
                    Log in
                    <i class="bi bi-arrow-right"></i>
                </button>
            </div>
        </form>
    </section>
{% endblock %}
