<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}Henrik A. Christensen{% endblock %}</title>
        <meta name="description" content="{% block meta_description %}I build practical software with PHP, Symfony, APIs, iOS and AI/MCP workflows.{% endblock %}">
        <meta name="robots" content="index, follow">

        <meta property="og:type" content="website">
        <meta property="og:site_name" content="Henrik A. Christensen">
        <meta property="og:title" content="{% block og_title %}Henrik A. Christensen - Software Developer{% endblock %}">
        <meta property="og:description" content="{% block og_description %}I build practical software with PHP, Symfony, APIs, iOS and AI/MCP workflows.{% endblock %}">
        <meta property="og:url" content="{{ app.request.uri }}">
        <meta property="og:image" content="{{ absolute_url(asset('social-card.png')) }}">
        <meta property="og:image:type" content="image/png">
        <meta property="og:image:width" content="1729">
        <meta property="og:image:height" content="910">

        <meta name="twitter:card" content="summary_large_image">
        <meta name="twitter:title" content="{% block twitter_title %}Henrik A. Christensen - Software Developer{% endblock %}">
        <meta name="twitter:description" content="{% block twitter_description %}I build practical software with PHP, Symfony, APIs, iOS and AI/MCP workflows.{% endblock %}">
        <meta name="twitter:image" content="{{ absolute_url(asset('social-card.png')) }}">
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text></svg>">

        {% block stylesheets %}
            <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
            <link rel="stylesheet" href="{{ asset('bootstrap-icons/bootstrap-icons.css') }}">
        {% endblock %}
    </head>
    <body class="bg-[#eef4f0] [font-family:'Avenir_Next',Avenir,ui-sans-serif,system-ui,sans-serif] text-[#13251f] antialiased">
        <main>
            {% block body %}{% endblock %}
        </main>

        <footer class="border-t border-[#c8d7d0] bg-[#fbfcfa] py-8">
            <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-5 px-5 text-sm text-[#5a6963] md:flex-row">
                <p>&copy; {{ 'now' | date('Y') }} Henrik A. Christensen</p>

                <div class="flex items-center gap-4">
                    <a class="text-[#5a6963] transition hover:text-[#13251f]" href="https://twitter.com/henrikabel" target="_blank" rel="noopener noreferrer" aria-label="Henrik A. Christensen on Twitter">
                        <i class="bi bi-twitter-x text-xl"></i>
                    </a>

                    <a class="text-[#5a6963] transition hover:text-[#13251f]" href="https://github.com/henrikac" target="_blank" rel="noopener noreferrer" aria-label="Henrik A. Christensen on GitHub">
                        <i class="bi bi-github text-xl"></i>
                    </a>

                    <a class="text-[#5a6963] transition hover:text-[#13251f]" href="https://www.linkedin.com/in/henrikac" target="_blank" rel="noopener noreferrer" aria-label="Henrik A. Christensen on LinkedIn">
                        <i class="bi bi-linkedin text-xl"></i>
                    </a>
                </div>
            </div>
        </footer>

        {% block javascripts %}
            {{ importmap('app') }}
        {% endblock %}
    </body>
</html>
